{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user account information and preferences.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Transformation": {
      "title": "Transformation History",
      "description": "Records of image and video transformations performed by the user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["image", "video"] },
        "originalUrl": { "type": "string" },
        "transformedUrl": { "type": "string" },
        "style": { "type": "string" },
        "config": { "type": "object" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "style", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile documents."
    },
    "/transformations/{transformationId}": {
      "schema": "Transformation",
      "description": "History of transformations."
    }
  }
}
